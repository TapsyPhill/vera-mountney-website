# =============================================================================
# Vera Mountney Website — Environment Configuration
# Copy this file to `.env` and fill in your values.
# Never commit `.env` to git (it is gitignored).
# =============================================================================

# --- Book purchase URLs (used at build time) ---
VITE_BOOK_BUY_URL_EN=https://example.com/buy-when-the-bats-fly-en
VITE_BOOK_BUY_URL_DE=https://example.com/buy-wenn-fledermaeuse-fliegen-de
VITE_BOOK_AUTHOR_URL=https://vera-mountney.de/book

# --- AI Chatbot Configuration ---
# Set to "true" to enable AI-powered responses (falls back to local knowledge if unavailable)
VITE_ENABLE_AI_CHAT=false

# Provider: local | openai | ollama | gemini | anthropic | groq
VITE_AI_PROVIDER=ollama

# OpenAI
VITE_OPENAI_API_KEY=

# Ollama (local or remote)
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_API_KEY=
VITE_OLLAMA_MODEL=llama3.2

# Google Gemini
VITE_GEMINI_API_KEY=

# Anthropic Claude
VITE_ANTHROPIC_API_KEY=

# Groq (fast inference)
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: Other API keys for future features ---
# SCRAPINGBEE_API_KEY=
# FIRECRAWL_API_KEY=
# APIFY_API_TOKEN=
# HF_TOKEN=

# =============================================================================
# SECURITY NOTE
# VITE_ prefixed variables are embedded in the client bundle at build time.
# For production, consider using a backend proxy to protect API keys.
# The local knowledge base works without any API keys.
# =============================================================================
